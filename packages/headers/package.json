{
  "name": "@netlify/headers",
  "version": "1.1.3",
  "description": "TypeScript implementation of Netlify's headers engine",
  "type": "module",
  "engines": {
    "node": "^14.16.0 || >=16.0.0"
  },
  "main": "./dist/main.js",
  "exports": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist/**/*",
    "server.d.ts"
  ],
  "scripts": {
    "build": "tsup-node",
    "dev": "tsup-node --watch",
    "prepack": "npm run build",
    "publint": "npx -y publint --strict",
    "test": "vitest run",
    "test:ci": "npm run build && vitest run",
    "test:dev": "vitest"
  },
  "keywords": [
    "netlify",
    "headers"
  ],
  "license": "MIT",
  "repository": "netlify/primitives",
  "bugs": {
    "url": "https://github.com/netlify/primitives/issues"
  },
  "author": "Netlify Inc.",
  "devDependencies": {
    "@netlify/dev-utils": "^2.2.0"
  }
}
